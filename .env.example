# Cloud Custodian Azure Container Apps - local development
# Copy this file to .env and fill in the secrets before running the CLI or VS Code launch configs.

# Azure subscription and identity
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000
AZURE_TENANT_ID=11111111-1111-1111-1111-111111111111
AZURE_CLIENT_ID=22222222-2222-2222-2222-222222222222
AZURE_CLIENT_SECRET=replace-with-secret-value

# Optional: Storage / policy locations used by CLI examples
C7N_POLICY_FILE=${PWD}/examples/policies/scheduled-policy.yml
AZURE_POLICY_STORAGE_URI=https://<storage-account>.blob.core.windows.net/policies/
AZURE_QUEUE_STORAGE_ACCOUNT=<storage-account-name>
AZURE_QUEUE_NAME=c7n-events

# Logging / output overrides
C7N_OUTPUT_DIR=/tmp/c7n-output
C7N_LOG_LEVEL=DEBUG
