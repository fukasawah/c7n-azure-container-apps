#!/bin/sh
# .githooks/pre-commit
# Git pre-commit hook for lint and format checks
#
# To enable this hook, run:
#   git config core.hooksPath .githooks

set -e

echo "Running pre-commit checks..."

# Check if ruff is available
if ! command -v ruff > /dev/null 2>&1 && ! python -m ruff --version > /dev/null 2>&1; then
    echo "❌ ruff not found. Please install it first:"
    echo "   pip install ruff"
    exit 1
fi

# Get staged Python files
STAGED_PY_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.py$' || true)

if [ -z "$STAGED_PY_FILES" ]; then
    echo "No Python files staged. Skipping lint/format checks."
    exit 0
fi

echo "Checking staged Python files..."

# Run ruff check (linter)
echo "Running ruff check..."
if ! python -m ruff check $STAGED_PY_FILES; then
    echo ""
    echo "❌ Lint errors found. Please fix them before committing."
    echo "   Run: python -m ruff check --fix src/ tests/"
    exit 1
fi

# Run ruff format check
echo "Running ruff format check..."
if ! python -m ruff format --check $STAGED_PY_FILES; then
    echo ""
    echo "❌ Format errors found. Please format your code before committing."
    echo "   Run: python -m ruff format src/ tests/"
    exit 1
fi

echo "✅ All pre-commit checks passed!"
